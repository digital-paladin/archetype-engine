# Player Configuration
PLAYER_BIRTH_DATE=1990-01-01             # Your birthdate in YYYY-MM-DD format — drives "Overall Level" age display
OWNER_EMAIL=you@example.com             # Your Supabase auth email — used by seed/migrate scripts

# Server Configuration
PORT=3000
NODE_ENV=production

# ─── Supabase (Phase 1+) ─────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=                     # "anon public" key — safe to expose in frontend
SUPABASE_SERVICE_ROLE_KEY=             # "service_role" key — BACKEND ONLY, never expose to frontend

# Authentication — replaced by Supabase Auth in Phase 2 (Sprint 2)
# Keep these for single-user mode until auth migration is complete
AUTH_USERNAME=paladin
AUTH_PASSWORD=changeme123
AUTH_TOKEN=your-secret-token-here-generate-random-string

# ─── File Paths (DEPRECATED — Phase 1) ───────────────────────────────────────
# These will be removed once Supabase migration is complete.
# Still required for local dev until each route is migrated.
CHARACTER_FILE_PATH=/app/character-progression/character-sheet.md
JOURNAL_PATH=/app/character-progression/progression-report/daily manual journal compendium(final version).md

# ─── GitHub Sync (DEPRECATED — Phase 1) ──────────────────────────────────────
# Will be removed once Supabase is the persistence layer.
GITHUB_TOKEN=                          # PAT with repo scope
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main
GITHUB_JOURNAL_PATH=your-repo/backend/character-progression/progression-report/your-journal-filename.md

# Frontend URL — used for password-reset and magic-link email redirects
# Must match Supabase → Authentication → URL Configuration → Redirect URLs
FRONTEND_URL=http://localhost:4200

# CORS Configuration (add your frontend deployment URL after deployment)
CORS_ORIGIN=http://localhost:4200,https://your-frontend-deployment-url.vercel.app

# WebSocket Configuration
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=5000

# Fitbit Integration (optional — enables sleep/nutrition/vitals sync)
FITBIT_CLIENT_ID=                      # From dev.fitbit.com app registration
FITBIT_CLIENT_SECRET=                  # From dev.fitbit.com app registration
FITBIT_REDIRECT_URI=http://localhost:3000/api/fitbit/callback
FITBIT_TOKEN_PATH=                     # DEPRECATED Phase 1 — tokens will move to fitbit_tokens table
# DEPRECATED Phase 1 — tokens will move to fitbit_tokens table in Supabase
FITBIT_ACCESS_TOKEN=
FITBIT_REFRESH_TOKEN=

# Todoist Integration (optional — enables AI agent task creation/management)
# Get your personal API token at: https://app.todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=                     # Personal API token (no OAuth needed for single-user)
