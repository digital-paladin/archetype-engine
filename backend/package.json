{
  "name": "digital-paladin-backend",
  "version": "1.0.0",
  "description": "Backend API for Digital Paladin character progression system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec \"ts-node -r dotenv/config\" src/server.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "seed:stats": "ts-node --transpile-only src/scripts/seed_character_stats.ts",
    "seed:quest-lines": "ts-node --transpile-only src/scripts/seed_quest_lines.ts",
    "patch:may17-stats": "ts-node --transpile-only src/scripts/patch_may17_character_stats.ts",
    "patch:owner-birth-date": "ts-node --transpile-only src/scripts/upsert_owner_birth_date.ts"
  },
  "keywords": [
    "character-progression",
    "gamification",
    "markdown-parser",
    "rest-api"
  ],
  "author": "digital-paladin",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "axios": "^1.17.0",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "socket.io": "^4.6.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.43.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
