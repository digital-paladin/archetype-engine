{
  "name": "character-progression-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "dotenv -e e2e/.env.playwright -- playwright test",
    "e2e:ui": "dotenv -e e2e/.env.playwright -- playwright test --ui",
    "e2e:debug": "dotenv -e e2e/.env.playwright -- playwright test --debug",
    "e2e:report": "playwright show-report"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rot-js": "^2.2.1",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "three": "^0.170.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@iconify-json/game-icons": "^1.2.3",
    "@playwright/test": "^1.59.1",
    "@types/jasmine": "^5.1.13",
    "@types/three": "^0.170.0",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
