# Playwright credentials — DO NOT COMMIT
# Copy this file to .env.playwright and fill in real values.

PLAYWRIGHT_BASE_URL=https://your-frontend.vercel.app
PLAYWRIGHT_API_URL=https://your-backend.up.railway.app
PLAYWRIGHT_USERNAME=your_username_here
PLAYWRIGHT_PASSWORD=your_password_here

# Optional — thin onboarding e2e (onboarding.spec.ts). If unset, a unique demo email is generated.
